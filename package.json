  "files": [
    "dist"
  ],
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
